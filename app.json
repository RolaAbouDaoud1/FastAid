{
  "expo": {
    "scheme": "fastaidapp",
    "name": "AmbulanceHospitalSystem",
    "slug": "AmbulanceHospitalSystem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/FastAid-Logo (2).png",
      "resizeMode": "contain",
      "backgroundColor": "#2d857c"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/FastAid-Logo (2).png",
        "backgroundColor": "#2d857c"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
